{
  "manifest_version": 3,
  "name": "FormStatus",
  "version": "1.0.0",
  "description": "Monitor and check your web forms status directly from your browser",
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://app.formstatus.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/fs-icon.png",
      "32": "icons/fs-icon.png",
      "48": "icons/fs-icon.png",
      "128": "icons/fs-icon.png"
    }
  },
  "icons": {
    "16": "icons/fs-icon.png",
    "32": "icons/fs-icon.png",
    "48": "icons/fs-icon.png",
    "128": "icons/fs-icon.png"
  }
}
